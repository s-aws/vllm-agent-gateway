    {
      "id": "implementation.workflow",
      "description": "Controller-owned controlled small-change draft/apply workflow with approval gates, patch previews, verification, and rollback metadata.",
      "default_role_id": "implementer/default",
      "allowed_role_ids": [
        "implementer/default"
      ],
      "controller_tool_ids": [
        "git_ls_files",
        "read_file",
        "run_tests"
      ],
      "conditional_controller_tool_ids": [],
      "controller_actions": [
        {
          "tool_id": "git_ls_files",
          "action": "confirm_tracked_apply_targets",
          "scope": "target_root",
          "result_artifacts": [
            "implementation_plan",
            "implementation_report"
          ]
        },
        {
          "tool_id": "read_file",
          "action": "read_packet_target_files",
          "scope": "target_root",
          "result_artifacts": [
            "implementation_plan",
            "implementation_report"
          ]
        },
        {
          "tool_id": "run_tests",
          "action": "run_controller_declared_verification_commands",
          "scope": "target_root",
          "result_artifacts": [
            "implementation_report"
          ]
        }
      ],
      "model_visible_tool_ids": []
    },
    {
      "id": "documenter.review",
      "description": "Bounded document review through the controller service.",
      "default_role_id": "documenter/default",
      "allowed_role_ids": [
        "documenter/default"
      ],
      "controller_tool_ids": [
        "git_ls_files",
        "read_file"
      ],
      "conditional_controller_tool_ids": [
        {
          "when": {
            "document_scope": "all"
          },
          "tool_ids": [
            "scan_files"
          ]
        }
      ],
      "controller_actions": [
        {
          "tool_id": "git_ls_files",
          "action": "discover_tracked_files",
          "scope": "target_root",
          "result_artifacts": [
            "document_manifest",
            "review_plan",
            "json_report"
          ]
        },
        {
          "tool_id": "read_file",
          "action": "read_reviewed_documents",
          "scope": "target_root",
          "result_artifacts": [
            "json_report",
            "run_state"
          ]
        },
        {
          "tool_id": "scan_files",
          "action": "discover_all_files",
          "scope": "target_root",
          "result_artifacts": [
            "document_manifest",
            "review_plan",
            "json_report"
          ]
        }
      ],
      "model_visible_tool_ids": []
    },
    {
      "id": "execution_planning.plan",
