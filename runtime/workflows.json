          "scope": "target_root",
          "result_artifacts": [
            "context_results",
            "impact_map"
          ]
        },
        {
          "tool_id": "git_grep",
          "action": "bounded_exact_string_lookup",
          "scope": "target_root",
          "result_artifacts": [
            "context_results",
            "impact_map"
          ]
        },
        {
          "tool_id": "read_file",
          "action": "read_selected_context_files",
          "scope": "target_root",
          "result_artifacts": [
            "context_results",
            "execution_plan"
          ]
        }
      ],
      "model_visible_tool_ids": []
    },
    {
