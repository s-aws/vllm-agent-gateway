{
  "schema_version": 1,
  "kind": "retrieval_first_context_strategy_design_policy",
  "phase": 215,
  "priority_backlog_id": "P0-M6-215",
  "milestone_ids": [
    "M6",
    "M8"
  ],
  "policy_version": "0.1.0",
  "purpose": "Define the retrieval-first context strategy contract before indexing, retrieval-backed chat, artifact paging, or context-strategy routing implementation begins.",
  "phase214_precondition": {
    "report_path": "runtime-state/phase214/phase214-large-corpus-context-budget-inventory-report.json",
    "required_status": "passed",
    "required_phase215_ready": true,
    "minimum_estimated_token_count": 384000,
    "raw_1m_prompt_support_proven_must_be": false
  },
  "required_strategy_ids": [
    "direct_context",
    "retrieval",
    "chunked_investigation",
    "summarization",
    "artifact_paging",
    "refusal"
  ],
  "strategy_definitions": [
    {
      "strategy_id": "direct_context",
      "purpose": "Use only when the selected evidence can fit inside the current target input budget without unsafe trimming.",
      "use_when": [
        "target evidence is small and bounded",
        "estimated selected input tokens are within the gateway target input limit",
        "no durable index is required"
      ],
      "forbidden_when": [
        "estimated corpus tokens exceed the target input limit and no evidence subset has been selected",
        "the request asks to stuff the full corpus into one prompt",
        "target root is unapproved"
      ],
      "budget_rule": "selected_input_tokens <= Phase 214 target input limit",
      "evidence_requirements": [
        "source_refs",
        "source_hashes",
        "confidence",
        "limitations"
      ],
      "output_contract": [
        "answer first",
        "cite selected files",
        "state that only selected context was read"
      ]
    },
    {
      "strategy_id": "retrieval",
      "purpose": "Use when a large corpus needs targeted evidence lookup through an approved safe index or equivalent bounded retrieval path.",
      "use_when": [
        "prompt asks for specific symbols, identifiers, routes, configuration values, or source evidence",
        "corpus exceeds direct prompt budget",
        "index safety governance has passed"
      ],
      "forbidden_when": [
        "index safety governance has not passed",
        "source hashes are stale",
        "retrieved chunks lack source references"
      ],
      "budget_rule": "retrieved_chunks + answer_budget <= phase214.target_input_limit",
      "evidence_requirements": [
        "retrieval_query",
        "chunk_refs",
        "source_refs",
        "source_hashes",
        "confidence",
        "missing_context",
        "limitations"
      ],
      "output_contract": [
        "separate direct retrieved evidence from inferred summary",
        "include missing-context caveats",
        "do not claim full-corpus coverage"
      ]
    },
    {
      "strategy_id": "chunked_investigation",
      "purpose": "Use when a task needs multi-step traversal over a corpus that cannot be answered from one retrieval pass.",
      "use_when": [
        "prompt asks for a flow, dependency chain, or cross-cutting behavior",
        "multiple bounded retrieval or scan steps are needed",
        "intermediate findings must be persisted as artifacts"
      ],
      "forbidden_when": [
        "request can be answered by a single exact lookup",
        "the plan would mutate protected source",
        "the plan lacks stop conditions"
      ],
      "budget_rule": "each chunk step must fit phase214.target_input_limit independently",
      "evidence_requirements": [
        "step_plan",
        "chunk_refs",
        "source_refs",
        "source_hashes",
        "confidence",
        "unknowns",
        "limitations"
      ],
      "output_contract": [
        "show investigation steps",
        "summarize each completed chunk",
        "state next unresolved evidence step"
      ]
    },
    {
      "strategy_id": "summarization",
      "purpose": "Use for high-level corpus orientation where representative source selection is acceptable and full coverage is not claimed.",
      "use_when": [
        "prompt asks for architecture overview, map, or summary",
        "representative sampling is acceptable",
        "answer can disclose selection method and confidence"
      ],
      "forbidden_when": [
        "prompt asks for exhaustive proof",
        "prompt asks for exact implementation details without evidence lookup",
        "summary would hide missing source coverage"
      ],
      "budget_rule": "sampled evidence + summary budget <= phase214.target_input_limit",
      "evidence_requirements": [
        "selection_strategy",
        "source_refs",
        "representative_source_refs",
        "source_hashes",
        "confidence",
        "limitations",
        "sampling_limitations"
      ],
      "output_contract": [
        "answer first",
        "show source-selection strategy",
        "label sampled versus exhaustive evidence"
      ]
    },
    {
      "strategy_id": "artifact_paging",
      "purpose": "Use when the user needs a long answer, large evidence list, or multi-part report that should stay useful in chat while detailed evidence is paged to artifacts.",
      "use_when": [
        "answer would exceed chat-usefulness limits",
        "many source refs or chunks must remain traceable",
        "chat should show a concise summary plus artifact pointers"
      ],
      "forbidden_when": [
        "chat response would become artifact-only",
        "artifact pages omit source continuity",
        "output format parity cannot be preserved"
      ],
      "budget_rule": "chat summary must fit answer budget; artifact pages must carry source continuity",
      "evidence_requirements": [
        "page_manifest",
        "source_refs",
        "source_hashes",
        "continuation_markers",
        "confidence",
        "limitations"
      ],
      "output_contract": [
        "chat-visible answer remains useful",
        "artifact pages are traceable",
        "default and JSON formats preserve the same answer contract"
      ]
    },
    {
      "strategy_id": "refusal",
      "purpose": "Use when the request is unsafe, unsupported, unapproved, stale, under-specified, or attempts raw prompt stuffing.",
      "use_when": [
        "target root is missing or unapproved",
        "request asks for raw 1M prompt stuffing",
        "index safety is missing or stale",
        "ignored, private, or secret-like content is requested"
      ],
      "forbidden_when": [
        "a supported bounded strategy can safely answer the request"
      ],
      "budget_rule": "no repository content is loaded beyond the evidence needed to explain the refusal",
      "evidence_requirements": [
        "refusal_reason",
        "safe_alternative",
        "required_next_step"
      ],
      "output_contract": [
        "state the refusal reason",
        "give a safe recovery path",
        "do not leak sensitive content"
      ]
    }
  ],
