{
  "schema_version": 1,
  "kind": "contextless_audit_scorecard_policy",
  "phase": 149,
  "priority_backlog_id": "P0-BB-020",
  "policy_version": "1.0.0",
  "purpose": "Consolidate contextless audit and blind-baseline evidence into a deterministic scorecard for founder review. This scorecard is not a substitute for blind-baseline-first chat-quality tests and does not grant release approval.",
  "recursive_policy_path": "runtime/recursive_blind_testing_policy.json",
  "authority_policy": {
    "blind_evaluator_is_pass_fail_authority": false,
    "scorecard_grants_release_approval": false,
    "deterministic_validator_is_pass_fail_authority": true
  },
  "release_signal_values": [
    "blocked",
    "needs_review",
    "evidence_complete_not_sufficient",
    "candidate_ready_for_founder_review"
  ],
  "score_floors": {
    "aggregate_minimum": 85,
    "source_minimum": 85,
    "dimension_minimum": 70
  },
  "scoring_dimensions": [
    {
      "id": "blind_baseline_before_local",
      "points": 20,
      "objective_predicate": "Fresh local-model drift evidence references governed blind-baseline hashes before local output comparison."
    },
    {
      "id": "context_isolation",
      "points": 15,
      "objective_predicate": "Recursive audit reports and policy prove fork_context=false and no session-history context."
    },
    {
      "id": "chat_visible_answer_quality",
      "points": 15,
      "objective_predicate": "Founder smoke and chat transcript quality reports pass with no blocker findings."
    },
    {
      "id": "route_skill_tool_evidence",
      "points": 15,
      "objective_predicate": "Gateway and AnythingLLM routes, run IDs, selected workflows, skills, or tools are recorded."
    },
    {
      "id": "fixture_mutation_safety",
      "points": 15,
      "objective_predicate": "Protected frozen fixture hashes and target-changed-file summaries show no new mutation."
    },
    {
      "id": "repair_rerun_traceability",
      "points": 10,
      "objective_predicate": "Accepted audit findings have validation references and current failure-to-roadmap output has no unapproved blocker proposal."
    },
    {
      "id": "residual_risk_handling",
      "points": 10,
      "objective_predicate": "Critical/high residual risks, blockers, findings, and next actions are zero or explicitly disposed."
    }
  ],
  "hard_blocker_codes": [
    "missing_required_artifact",
    "malformed_required_artifact",
    "source_status_failed",
    "source_kind_mismatch",
    "source_phase_mismatch",
    "blind_agent_release_authority",
    "context_leakage",
    "missing_blind_baseline_order",
    "missing_local_gateway_anythingllm_evidence",
    "protected_fixture_mutation",
    "missing_repair_rerun_trace",
    "unresolved_critical_high_risk",
    "source_score_below_floor",
    "aggregate_score_below_floor"
  ],
  "forbidden_blind_authority_markers": [
    "blind evaluator approved release",
    "blind agent approved release",
    "contextless evaluator approved release",
    "blind evaluator is pass/fail authority",
    "blind agent is pass/fail authority"
  ],
  "required_target_roots": [
    "/mnt/c/coinbase_testing_repo_frozen_tmp",
    "/mnt/c/coinbase_testing_repo_frozen_tmp.github"
  ],
  "required_routes": [
    "gateway",
    "anythingllm"
  ],
  "source_artifacts": [
    {
      "id": "phase120_baseline_corpus",
      "type": "baseline_corpus",
      "path": "runtime-state/baseline-corpus/phase120-baseline-corpus-report.json",
