  },
  "live_validation_requirements": {
    "blind_baseline_before_local_output": true,
    "anythingllm_required_when_applicable": true,
    "required_targets": [
      "localhost_8000",
      "gateway_8300",
      "controller_8400",
      "workflow_router_8500",
      "documenter_8205",
      "anythingllm"
    ],
    "required_target_roots": [
      "/mnt/c/coinbase_testing_repo_frozen_tmp",
      "/mnt/c/coinbase_testing_repo_frozen_tmp.github"
    ]
  },
  "promotion_requirements": {
    "batch_admission_must_pass": true,
    "prompt_coverage_starts_planned": true,
    "regression_skeleton_must_fail_closed": true,
    "phase193_readiness_must_pass": true,
    "manual_registry_append_forbidden": true,
    "candidate_absent_from_runtime_registries": true,
    "runtime_registry_hashes_must_match_before_after": true
