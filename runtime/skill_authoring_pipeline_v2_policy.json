  "acceptance_marker": "PHASE194 SKILL AUTHORING PIPELINE V2 PASS",
  "description": "Governed V2 draft-packet admission checklist for creating small deterministic L1/L2 skill candidates from observed prompt gaps without manual prompt injection or runtime registry mutation.",
  "gate_scope": "draft_packet_admission_only",
  "proof_complete_required": false,
  "candidate_contract": {
