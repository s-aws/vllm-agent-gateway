      "skill_body",
      "prompt_coverage_entry",
      "eval_skeleton",
      "docs_stub",
      "docs_example",
      "regression_test_skeleton",
      "authoring_pipeline_plan"
    ],
    "required_eval_gate_ids": [
      "routing",
      "artifact_contract",
      "natural_language_chat_output",
      "prompt_coverage",
      "blind_baseline_first",
      "holdout_prompt",
      "live_gateway",
      "anythingllm_when_applicable",
      "fixture_parity"
    ],
    "minimum_prompt_examples": 2,
    "minimum_holdout_prompts": 2,
    "minimum_acceptance_criteria": 3
  },
  "required_source_paths": {
    "skill_registry": "runtime/skills.json",
    "skill_evals": "runtime/skill_evals.json",
    "prompt_skill_coverage": "runtime/prompt_skill_coverage.json",
